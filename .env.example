VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service-role key — server/cron only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
RESEND_API_KEY=your_resend_api_key

# Sentry — public client key (DSN). Safe to expose to the browser.
PUBLIC_SENTRY_DSN=your_sentry_dsn

# Admin panel credentials — server-only, never expose to the browser.
# Set these in your hosting provider's environment variables (Netlify/Cloudflare),
# NOT in committed files. Rotate immediately if ever leaked.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_secret
